# ═══════════════════════════════════════════════════════════════════════
# CONbot5 SUPREME — Environment Variables
# Copy to .env and fill in ALL values before deploying
# ═══════════════════════════════════════════════════════════════════════

# ─── Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ─── Roles ────────────────────────────────────────────────────────────
DJ_ROLE_ID=           # Leave blank = everyone is DJ

# ─── Services ─────────────────────────────────────────────────────────
BOT_PORT=3010
API_PORT=3020
WS_PORT=3030
API_URL=http://localhost:3020
WS_URL=http://localhost:3030

# Shared secret between bot and API (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
API_BOT_TOKEN=

# ─── YouTube (recommended) ────────────────────────────────────────────
YOUTUBE_COOKIE=       # F12 > Application > Cookies > .youtube.com > VISITOR_INFO1_LIVE

# ─── Spotify (optional — improves Spotify resolution) ────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ─── Timing ───────────────────────────────────────────────────────────
PULSE_INTERVAL=25000
RECONNECT_DELAY=5000

# ─── Desktop ──────────────────────────────────────────────────────────
NODE_ENV=production
